{
  "ConnectionStrings": {
    "PlatformDb": "Server=(localdb)\\MSSQLLocalDB;Database=PeopleGrid_PlatformDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "PeopleGrid",
    "Audience": "PeopleGrid",
    "SigningKey": "CHANGE_ME_TO_A_LONG_SECURE_KEY_FOR_PRODUCTION_123456789",
    "AccessTokenMinutes": 60
  },
  "Auth": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "RefreshTokenDays": 7,
    "PasswordResetTokenMinutes": 30,
    "PasswordHistoryLimit": 5,
    "PasswordExpiryDays": 90
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
